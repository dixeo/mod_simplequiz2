{{!
    @template mod_simplequiz2/simplequiz_container

    Global container for simple quiz view

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * name mod title
    * intro formatted mod intro (with format_module_intro())
    * questions array of questions data

    Example context (json):
    {
        "name": "A simple quiz activity",
        "intro": "<p>Description of a simple quiz</p>",
        "questions": [
            {
                "order": 1,
                "text": "<p>Question text</p>",
                "islast": true,
                "answers": [
                    {"order": 0, "text": "First answer"},
                    {"order": 1, "text": "Second answer"}
                ]
            }
        ]
    }
}}


<div id="simplequiz_container" class="mb-3">
    <div id="simplequiz-questions">
        {{#questions}}
            {{> mod_simplequiz2/question_container}}
        {{/questions}}
    </div>
    <div id="simplequiz-result">
        <div class="fireworks"></div>
        <div id="details">
            <p class="current-score" tabindex="0"></p>
            <p class="best-score" tabindex="0"></p>
            <p tabindex="0">{{#str}} result-help, simplequiz2{{/str}}</p>
            <button class="restart" tabindex="0">{{#str}} restart, simplequiz2{{/str}}</button>
        </div>
        <div class="fireworks"></div>
    </div>
</div>